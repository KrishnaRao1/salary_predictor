# Step 5 — Scrape Stats & Contracts from Basketball Reference

```{r scrape-data, cache=TRUE, cache.extra=SEASON_YEAR}
# cache.extra=SEASON_YEAR forces a cache bust when the year changes, so
# stale data from a prior season is never silently reused.

cat("Fetching per-game stats...\n")
basic_raw <- bref_table(
  paste0("https://www.basketball-reference.com/leagues/NBA_", SEASON_YEAR, "_per_game.html"),
  "per_game_stats"
)

cat("Fetching advanced stats...\n")
adv_raw <- bref_table(
  paste0("https://www.basketball-reference.com/leagues/NBA_", SEASON_YEAR, "_advanced.html"),
  "advanced"
)

cat("Fetching contract data...\n")
money_raw <- bref_table(
  "https://www.basketball-reference.com/contracts/players.html",
  "player-contracts",
  multi_header = TRUE
)

cat("Done.\n")
```

---

# Step 6 — Clean & Merge

```{r clean-and-merge}
# ── Per-game ──────────────────────────────────────────────────────────────────
basic_df <- basic_raw %>%
  drop_junk_cols() %>%
  filter(Player != "Player") %>%
  mutate(Player = clean_name(Player)) %>%
  select(-any_of(c("G","GS","ORB","DRB","PF","Awards",
                   "FT","FTA","FG","FGA","FG%","Rk"))) %>%
  distinct(Player, .keep_all = TRUE)

# ── Advanced ──────────────────────────────────────────────────────────────────
adv_df <- adv_raw %>%
  drop_junk_cols() %>%
  filter(Player != "Player") %>%
  mutate(Player = clean_name(Player)) %>%
  select(-any_of(c("Age","Team","Pos","G","GS","MP","PER","Awards","Rk"))) %>%
  distinct(Player, .keep_all = TRUE)

# ── Contracts ─────────────────────────────────────────────────────────────────
money_df <- money_raw %>%
  drop_junk_cols() %>%
  filter(Player != "Player") %>%
  mutate(Player = clean_name(Player)) %>%
  select(-any_of(c("Tm","2024-25","2027-28","2028-29","2029-30","Rk"))) %>%
  distinct(Player, .keep_all = TRUE)

# ── Merge stats + contracts ───────────────────────────────────────────────────
combined_df <- basic_df %>%
  inner_join(adv_df,   by = "Player") %>%
  inner_join(money_df, by = "Player") %>%
  mutate(
    salary_clean = as.numeric(gsub("[$,]", "", .data[[SALARY_COL]])) / 1e6
  ) %>%
  mutate(across(all_of(FEATURES), ~ suppressWarnings(as.numeric(.))))

cat(sprintf("Players in combined dataset: %d\n", nrow(combined_df)))
```

```{r preview-merge, echo=FALSE}
combined_df %>%
  select(Player, any_of(c("Pos","Age","MP","TS%","USG%","VORP","BPM", SALARY_COL))) %>%
  head(8) %>%
  kable(caption = "Sample of merged dataset") %>%
  kable_styling(bootstrap_options = c("striped","hover","condensed"), full_width = FALSE)
```

