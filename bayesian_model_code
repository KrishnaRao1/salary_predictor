# Step 1 — Configuration

> **Only edit this chunk between seasons.**

```{r config}
# ── Season ────────────────────────────────────────────────────────────────────
SEASON_YEAR <- 2026

# ── Salary column ─────────────────────────────────────────────────────────────
# Must match the column name on the bball-ref contracts page exactly.
SALARY_COL  <- "2025-26"

# ── GitHub raw URL for the FA list CSV ────────────────────────────────────────
FA_CSV_URL <- "https://raw.githubusercontent.com/KrishnaRao1/salary_predictor/refs/heads/main/nba_2026_free_agents.csv"

# ── Features ──────────────────────────────────────────────────────────────────
# Stats the model uses to predict salary. Names must match bball-ref headers.
#
#   3P%  — three-point shooting efficiency
#   TS%  — true shooting % (overall scoring efficiency)
#   USG% — usage rate (how often the player has the ball)
#   VORP — value over replacement player
#   DWS  — defensive win shares
#   DBPM — defensive box plus/minus
#   AST% — assist percentage
#   TRB  — total rebounds per game
#   STL  — steals per game
#   BLK  — blocks per game
FEATURES <- c("3P%", "TS%", "USG%", "VORP", "DWS", "DBPM", "AST%", "TRB", "STL", "BLK")

# ── Model settings ─────────────────────────────────────────────────────────────
CHAINS  <- 4
ITER    <- 3000
WARMUP  <- 1000
SEED    <- 42

# ── Output ─────────────────────────────────────────────────────────────────────
OUTPUT_FILE <- paste0("NBA_Salary_Predictor_", SEASON_YEAR, ".xlsx")
```

