# Step 2 — Helper Functions

```{r helpers}
# ── bref_table ────────────────────────────────────────────────────────────────
# Fetches any bball-ref HTML table by its CSS id.
# multi_header = TRUE flattens tables with a two-row header (e.g. contracts).
# Fixes:
#   1. make.unique() — prevents "duplicate names" error in dplyr::filter()
#   2. Guarantees a column named "Player" exists
bref_table <- function(url, table_id, multi_header = FALSE) {
  Sys.sleep(4)
  page <- GET(url, user_agent("Mozilla/5.0 (compatible; R/rvest scraper)"))
  html <- read_html(content(page, as = "text"))
  node <- html %>% html_element(paste0("#", table_id))
  tbl  <- node %>% html_table(header = TRUE)

  if (multi_header) {
    colnames(tbl) <- as.character(unlist(tbl[1, ]))
    tbl <- tbl[-1, ]
  }

  colnames(tbl) <- make.unique(colnames(tbl), sep = "_")
  if (!"Player" %in% colnames(tbl)) colnames(tbl)[1] <- "Player"

  tbl
}

# ── drop_junk_cols ────────────────────────────────────────────────────────────
# Removes blank ("") or auto-numbered ("_1", "_2") columns left by rvest.
# Must run before filter() to prevent the "duplicate names" dplyr error.
drop_junk_cols <- function(df) {
  df[, !grepl("^(_\\d+)?$", colnames(df)), drop = FALSE]
}

# ── clean_name ────────────────────────────────────────────────────────────────
# Strips asterisks, daggers, and extra whitespace from player name strings.
# Applied to every player column before every join.
clean_name <- function(x) {
  x %>% str_trim() %>% str_remove_all("[\\*†]") %>% str_squish()
}

# ── scale_features ────────────────────────────────────────────────────────────
# Z-score standardisation. Uses X_means and X_sds set in the standardise chunk.
# Defined here so it is available in both the training and FA prediction steps.
scale_features <- function(df) {
  mat <- as.matrix(df %>% select(all_of(FEATURES)))
  sweep(sweep(mat, 2, X_means, "-"), 2, X_sds, "/")
}
```

