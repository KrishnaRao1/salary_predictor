# Step 12 — Export to Excel

Three tabs: All Contracts, FA Unsigned, FA Signed.

```{r export}
all_contracts <- df_model %>%
  arrange(desc(Gap)) %>%
  mutate(across(where(is.numeric), ~ round(., 1))) %>%
  select(Player,
         `Actual ($M)`    = salary_clean,
         `Predicted ($M)` = Predicted_Salary,
         `95% CI Low`     = Pred_Lower_95,
         `95% CI High`    = Pred_Upper_95,
         `Gap ($M)`       = Gap)

fa_signed_full <- fa_df %>%
  filter(Status == "Signed") %>%
  arrange(desc(Predicted_AAV)) %>%
  select(Player,
         `FA Type`             = FA_Type,
         `Actual New AAV ($M)` = Actual_New_AAV,
         `Predicted AAV ($M)`  = Predicted_AAV,
         `95% CI Low`          = Pred_Lower_95,
         `95% CI High`         = Pred_Upper_95,
         `Gap ($M)`            = Gap)

fa_unsigned_full <- fa_df %>%
  filter(Status == "Unsigned") %>%
  arrange(desc(Predicted_AAV)) %>%
  select(Player,
         `FA Type`            = FA_Type,
         `Predicted AAV ($M)` = Predicted_AAV,
         `95% CI Low`         = Pred_Lower_95,
         `95% CI High`        = Pred_Upper_95)

desktop_path <- file.path(path.expand("~"), "Desktop", OUTPUT_FILE)

sheets <- list(
  All_Contracts = as.data.frame(all_contracts),
  FA_Unsigned   = as.data.frame(fa_unsigned_full),
  FA_Signed     = as.data.frame(fa_signed_full)
)

write_xlsx(sheets, path = desktop_path)
cat(sprintf("Saved to Desktop: %s\n", desktop_path))
cat(sprintf("  All_Contracts: %d rows\n", nrow(sheets$All_Contracts)))
cat(sprintf("  FA_Unsigned:   %d rows\n", nrow(sheets$FA_Unsigned)))
cat(sprintf("  FA_Signed:     %d rows\n", nrow(sheets$FA_Signed)))
```

