# Step 10 — Predict: All Under-Contract Players

`Gap` = predicted minus actual. Positive = undervalued. Negative = overvalued.
95% CI lower bound is floored at $0M.

```{r predict-known}
pp_known <- posterior_predict(bayes_model, newdata = train_data)

df_model <- df_model %>%
  mutate(
    Predicted_Salary = round(colMeans(pp_known), 1),
    Pred_Lower_95    = pmax(round(apply(pp_known, 2, quantile, probs = 0.025), 1), 0),
    Pred_Upper_95    = round(apply(pp_known, 2, quantile, probs = 0.975), 1),
    Gap              = round(Predicted_Salary - salary_clean, 1)
  )
```

```{r table-all-contracts, echo=FALSE}
df_model %>%
  arrange(desc(Gap)) %>%
  mutate(across(where(is.numeric), ~ round(., 1))) %>%
  select(Player,
         `Actual ($M)`    = salary_clean,
         `Predicted ($M)` = Predicted_Salary,
         `95% CI Low`     = Pred_Lower_95,
         `95% CI High`    = Pred_Upper_95,
         `Gap ($M)`       = Gap) %>%
  kable(caption = "All Under-Contract Players — Predicted vs Actual Salary") %>%
  kable_styling(bootstrap_options = c("striped","hover","condensed"), full_width = FALSE) %>%
  row_spec(0, bold = TRUE)
```

