# Step 11 — Predict: 2026 Free Agents (Signed + Unsigned)

95% CI lower bound is floored at $0M.

```{r predict-fa}
X_fa_scaled       <- scale_features(fa_df)
fa_data           <- as.data.frame(X_fa_scaled)
colnames(fa_data) <- FEATURES

pp_fa <- posterior_predict(bayes_model, newdata = fa_data)

fa_df <- fa_df %>%
  mutate(
    Predicted_AAV = round(colMeans(pp_fa), 1),
    Pred_Lower_95 = pmax(round(apply(pp_fa, 2, quantile, probs = 0.025), 1), 0),
    Pred_Upper_95 = round(apply(pp_fa, 2, quantile, probs = 0.975), 1),
    Gap           = round(Predicted_AAV - Actual_New_AAV, 1)
  )
```

